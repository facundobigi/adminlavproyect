rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profilePath() {
      return /databases/$(database)/documents/admins/$(request.auth.uid);
    }

    function hasProfile() {
      return signedIn()
        && exists(profilePath())
        && get(profilePath()).data.active == true;
    }

    function profile() {
      return get(profilePath()).data;
    }

    function tenantForUser() {
      return profile().tenant == null ? request.auth.uid : profile().tenant;
    }

    function inTenant(tenantId) {
      return hasProfile() && tenantForUser() == tenantId;
    }

    function isAdmin(tenantId) {
      return inTenant(tenantId) && profile().role == 'admin';
    }

    function changedOnly(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    function validOrdenCreate(tenantId) {
      return inTenant(tenantId)
        && request.resource.data.estado == 'en_cola'
        && request.resource.data.tenant_id == tenantId;
    }

    function validOrdenStart() {
      return resource.data.estado == 'en_cola'
        && request.resource.data.estado == 'en_lavado'
        && request.resource.data.started_at == request.time
        && request.resource.data.puesto == null
        && changedOnly(['estado', 'started_at', 'puesto']);
    }

    function validOrdenFinish() {
      return resource.data.estado == 'en_lavado'
        && request.resource.data.estado == 'listo'
        && request.resource.data.finished_at == request.time
        && request.resource.data.puesto == null
        && changedOnly(['estado', 'finished_at', 'puesto']);
    }

    function validOrdenDeliver() {
      return resource.data.estado == 'listo'
        && request.resource.data.estado == 'entregado'
        && request.resource.data.delivered_at == request.time
        && request.resource.data.pago is map
        && request.resource.data.pago.monto is number
        && request.resource.data.pago.monto > 0
        && request.resource.data.pago.tipo in ['efectivo', 'transferencia', 'otro']
        && changedOnly(['estado', 'delivered_at', 'pago']);
    }

    function validOrdenUpdate(tenantId) {
      return inTenant(tenantId)
        && (
          validOrdenStart()
          || validOrdenFinish()
          || validOrdenDeliver()
        );
    }

    match /admins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /users/{tenantId} {
      allow read: if inTenant(tenantId);
      allow write: if false;

      match /config/{docId} {
        allow read: if inTenant(tenantId);
        allow write: if isAdmin(tenantId);
      }

      match /servicios/{docId} {
        allow read: if inTenant(tenantId);
        allow write: if isAdmin(tenantId);
      }

      match /clientes/{docId} {
        allow read, write: if inTenant(tenantId);
      }

      match /ordenes/{docId} {
        allow read: if inTenant(tenantId);
        allow create: if validOrdenCreate(tenantId);
        allow update: if validOrdenUpdate(tenantId);
        allow delete: if false;
      }

      match /gastos/{docId} {
        allow read, create: if inTenant(tenantId);
        allow update, delete: if isAdmin(tenantId);
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
